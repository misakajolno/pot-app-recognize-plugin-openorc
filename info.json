{
  "id": "plugin.com.pot-app.openorc",
  "plugin_type": "recognize",
  "icon": "openorc.png",
  "display": "OpenOCR",
  "homepage": "https://github.com/Topdu/OpenOCR",
  "needs": [
    {
      "key": "python_cmd",
      "display": "Python Command",
      "type": "input"
    },
    {
      "key": "bridge_script_path",
      "display": "Bridge Script Path",
      "type": "input"
    },
    {
      "key": "task",
      "display": "OpenOCR Task",
      "type": "select",
      "options": {
        "ocr": "ocr",
        "unirec": "unirec"
      }
    },
    {
      "key": "mode",
      "display": "OpenOCR Mode",
      "type": "select",
      "options": {
        "mobile": "mobile",
        "server": "server"
      }
    },
    {
      "key": "backend",
      "display": "OpenOCR Backend",
      "type": "select",
      "options": {
        "onnx": "onnx",
        "torch": "torch"
      }
    },
    {
      "key": "merge_lines",
      "display": "Merge Lines",
      "type": "select",
      "options": {
        "true": "true",
        "false": "false"
      }
    },
    {
      "key": "timeout_ms",
      "display": "Timeout (ms)",
      "type": "input"
    }
  ],
  "language": {
    "auto": "auto",
    "zh_cn": "zh",
    "zh_tw": "zh",
    "en": "en",
    "ja": "ja",
    "ko": "ko",
    "fr": "fr",
    "ru": "ru",
    "de": "de",
    "mn_cy": "ru"
  }
}
